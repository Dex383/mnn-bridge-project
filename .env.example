# MNN Bridge Configuration

# Android App Settings
BRIDGE_PORT=8080
BRIDGE_BIND_ADDRESS=127.0.0.1

# Data Exchange Paths (Android internal storage)
# Replace [package_name] with the actual app package
DATA_DIR=/sdcard/Android/data/[package_name]/files/
INPUT_FILE=input.bin
OUTPUT_FILE=output.bin

# Model Settings
MODELS_ROOT=/sdcard/models/
